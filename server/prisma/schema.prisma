// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum RoleName {
  FRESHER
  CLIENT
  MENTOR
}

model Role {
  id    Int      @id @default(autoincrement())
  name  RoleName @unique
  users User[]
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String?
  name         String
  roleId       Int
  role         Role      @relation(fields: [roleId], references: [id])
  googleId     String?   @unique
  githubId     String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      Profile?
  skills       UserSkill[]
  jobs        Job[]
  applications    Application[]  @relation("FresherApplications")
mentorReviews   MentorReview[] @relation("MentorReviews")
fresherReviews  MentorReview[] @relation("FresherReviews")
portfolio     PortfolioItem[]
}

model Profile {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id])
  bio           String?  @db.Text
  education     String?
  resumeUrl     String?
  githubUrl     String?
  linkedinUrl   String?
  hourlyRate    Float?
  availability  Boolean  @default(true)
  tier          Int      @default(1)
}

model Skill {
  id    Int         @id @default(autoincrement())
  name  String      @unique
  users UserSkill[]
}

model UserSkill {
  id       Int     @id @default(autoincrement())
  userId   Int
  skillId  Int
  verified Boolean @default(false)
  user     User    @relation(fields: [userId], references: [id])
  skill    Skill   @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}
model Job {
  id          Int       @id @default(autoincrement())
  title       String
  description String    @db.Text
  budget      Float
  tierRequired Int      @default(1)
  skills      String
  isRemote    Boolean   @default(true)
  status      JobStatus @default(OPEN)
  clientId    Int
  client      User      @relation(fields: [clientId], references: [id])
  createdAt   DateTime  @default(now())
  applications Application[]
  updatedAt   DateTime  @updatedAt
}

enum JobStatus {
  OPEN
  CLOSED
  IN_PROGRESS
}
model Application {
  id          Int               @id @default(autoincrement())
  jobId       Int
  fresherId   Int
  coverLetter String?           @db.Text
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  job         Job               @relation(fields: [jobId], references: [id])
  fresher     User              @relation("FresherApplications", fields: [fresherId], references: [id])
  review      MentorReview?
  @@unique([jobId, fresherId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

model MentorReview {
  id            Int         @id @default(autoincrement())
  applicationId Int         @unique
  mentorId      Int
  fresherId     Int
  rating        Int
  review        String      @db.Text
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id])
  mentor        User        @relation("MentorReviews", fields: [mentorId], references: [id])
  fresher       User        @relation("FresherReviews", fields: [fresherId], references: [id])
}
model PortfolioItem {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String   @db.Text
  techStack   String
  githubUrl   String?
  liveUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}